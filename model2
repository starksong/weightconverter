<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>专业重量转换工具</title>
    <style>
        :root {
            --primary-color: #007aff;
            --bg-color: #f0f2f5;
        }
        body {
            font-family: -apple-system, system-ui, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            padding: 40px 20px;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 400px;
        }
        h2 { text-align: center; color: #1d1d1f; margin-bottom: 25px; }
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        .input-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 6px; color: #86868b; font-size: 13px; font-weight: 600; }
        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #d2d2d7;
            border-radius: 8px;
            font-size: 16px;
            transition: all 0.2s;
            box-sizing: border-box;
        }
        input:focus { border-color: var(--primary-color); outline: none; box-shadow: 0 0 0 3px rgba(0,122,255,0.1); }
        .btn-clear {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            background-color: #f5f5f7;
            border: none;
            border-radius: 8px;
            color: #ff3b30;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }
        .btn-clear:hover { background-color: #e8e8ed; }
        .divider { height: 1px; background: #eee; margin: 20px 0; }
    </style>
</head>
<body>

<div class="container">
    <h2>重量转换工具</h2>
    
    <div class="grid">
        <div class="input-group">
            <label>公斤 (KG)</label>
            <input type="number" id="kg" placeholder="0" oninput="convert('kg')">
        </div>
        <div class="input-group">
            <label>磅 (LB)</label>
            <input type="number" id="lb" placeholder="0" oninput="convert('lb')">
        </div>
    </div>

    <div class="grid">
        <div class="input-group">
            <label>克 (G)</label>
            <input type="number" id="g" placeholder="0" oninput="convert('g')">
        </div>
        <div class="input-group">
            <label>盎司 (OZ)</label>
            <input type="number" id="oz" placeholder="0" oninput="convert('oz')">
        </div>
    </div>

    <div class="divider"></div>

    <button class="btn-clear" onclick="clearAll()">清空所有数据</button>
</div>

<script>
    // 换算基准：以“克”为中心进行换算
    const units = {
        kg: 1000,
        g: 1,
        lb: 453.59237,
        oz: 28.34952
    };

    function convert(source) {
        const value = document.getElementById(source).value;
        
        if (value === "") {
            clearAll();
            return;
        }

        const amount = parseFloat(value);
        // 先转换成克 (G)
        const grams = amount * units[source];

        // 算出其他所有单位
        for (let unit in units) {
            if (unit !== source) {
                const result = grams / units[unit];
                // 如果结果很小则保留更多小数，否则保留2位
                document.getElementById(unit).value = result < 0.01 ? result.toFixed(4) : result.toFixed(2);
            }
        }
    }

    function clearAll() {
        ['kg', 'lb', 'g', 'oz'].forEach(id => {
            document.getElementById(id).value = "";
        });
    }
</script>

</body>
</html>
